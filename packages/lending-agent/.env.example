# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key
ANTHROPIC_API_KEY=

# OpenAI API key
OPENAI_API_KEY=

# Claude model to use
MODEL=gpt-4o-mini

# BIP-39 seed phrase for the WDK wallet (12 or 24 words)
# WARNING: this controls a live wallet — never commit a real seed
WDK_SEED=

# ── Optional ──────────────────────────────────────────────────────────────────

# 1delta API key — raises rate limits (get one at https://auth.1delta.io)
ONEDELTA_API_KEY=

# Set to "true" to skip actual transaction submission and just print calldata
DRY_RUN=true

# Bearer token to protect the /settle/* endpoints
API_SECRET=

# Order backend
ORDER_BACKEND_URL=

# Chains to run the settlement job on
CRON_CHAIN_IDS=42161

# Only executes if profitable when true
ECONOMIC_MODE=false