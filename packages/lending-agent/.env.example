# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key for Claude Opus 4.6
ANTHROPIC_API_KEY=

# BIP-39 seed phrase for the WDK wallet (12 or 24 words)
# WARNING: this controls a live wallet — never commit a real seed
WDK_SEED=

# ── Optional ──────────────────────────────────────────────────────────────────

# 1delta API key — raises rate limits (get one at https://auth.1delta.io)
ONEDELTA_API_KEY=

# Claude model to use (default: claude-opus-4-6)
MODEL=

# Token to deposit (default: USDT)
TOKEN=

# USD value to deposit (default: 1)
AMOUNT=

# Restrict to a specific chain ID, e.g. 42161 for Arbitrum (default: all chains)
CHAIN_FILTER=

# Set to "true" to skip actual transaction submission and just print calldata
DRY_RUN=true
