{
  "name": "@wdk-hackathon/lending-agent",
  "version": "1.0.0",
  "description": "AI agent that finds the best lending market via 1delta MCP and executes deposits via WDK MCP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node --env-file=.env dist/index.js",
    "worker:dev": "wrangler dev worker.ts",
    "worker:deploy": "wrangler deploy worker.ts",
    "worker:tail": "wrangler tail",
    "wdk:http": "node ../wdk-mcp-toolkit/examples/http/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@1delta/settlement-sdk": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.8",
    "openai": "^6.32.0",
    "viem": "^2.47.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^20.10.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0",
    "wrangler": "^4.0.0"
  }
}
